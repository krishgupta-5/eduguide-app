rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to professors collection for all users
    match /professors/{professorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow read access to rating_summary collection for all users
    match /rating_summary/{ratingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Users can read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Ratings collection - authenticated users can read and write
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
